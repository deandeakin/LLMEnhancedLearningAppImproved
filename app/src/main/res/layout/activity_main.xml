<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/my_porcelain"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvMainTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Learning Assistant"
            android:textColor="@color/my_black"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Hello, Student"
            android:textColor="@color/my_black"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvNotification"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="You have 1 task due today."
            android:textColor="@color/my_charcoal"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvGeneratedTaskLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Generated Task"
            android:textColor="@color/my_plum"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvGeneratedTaskDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_card"
            android:padding="14dp"
            android:text="Practice a short quiz based on your selected interests and past learning activity."
            android:textColor="@color/my_charcoal"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvRecentActivityLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Recent Activity"
            android:textColor="@color/my_plum"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvRecentActivity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_card"
            android:padding="14dp"
            android:text="No recent activity yet."
            android:textColor="@color/my_charcoal"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnStartTask"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_primary_button"
            android:text="Open Task"
            android:textAllCaps="false"
            android:textColor="@color/my_porcelain"
            android:textStyle="bold"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_secondary_button"
            android:text="Logout"
            android:textAllCaps="false"
            android:textColor="@color/my_porcelain"
            app:backgroundTint="@null" />

    </LinearLayout>
</ScrollView>