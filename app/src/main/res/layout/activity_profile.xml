<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/my_porcelain"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvProfileTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profile"
            android:textColor="@color/my_black"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvProfileDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card"
            android:padding="14dp"
            android:text="Profile details section"
            android:textColor="@color/my_black"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvProfileStatsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Learning Stats"
            android:textColor="@color/my_plum"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvProfileStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_card"
            android:padding="14dp"
            android:text="Stats section."
            android:textColor="@color/my_black"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnViewHistory"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_secondary_button"
            android:text="View History"
            android:textAllCaps="false"
            android:textColor="@color/my_porcelain"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnShareProfile"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_secondary_button"
            android:text="Share Profile"
            android:textAllCaps="false"
            android:textColor="@color/my_porcelain"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnShowQrCode"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_secondary_button"
            android:text="Show QR Code"
            android:textAllCaps="false"
            android:textColor="@color/my_porcelain"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnUpgradeAccount"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_primary_button"
            android:text="Upgrade Account"
            android:textAllCaps="false"
            android:textColor="@color/my_porcelain"
            android:textStyle="bold"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnBackToHome"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_secondary_button"
            android:text="Back to Home"
            android:textAllCaps="false"
            android:textColor="@color/my_porcelain"
            app:backgroundTint="@null" />

    </LinearLayout>
</ScrollView>