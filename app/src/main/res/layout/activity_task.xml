<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/my_porcelain"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_ai_badge"
            android:paddingLeft="10dp"
            android:paddingTop="6dp"
            android:paddingRight="10dp"
            android:paddingBottom="6dp">

            <ImageView
                android:id="@+id/ivAiBadgeTask"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:contentDescription="AI icon"
                android:src="@drawable/bard" />

            <TextView
                android:id="@+id/tvAiBadgeTask"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="Generated by AI"
                android:textColor="@color/my_porcelain"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvTaskTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Generated Task 1"
            android:textColor="@color/my_black"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvTaskDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card"
            android:padding="14dp"
            android:text="Answer the question below. You can also ask for a hint or explanation."
            android:textColor="@color/my_charcoal"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvQuestion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Question will appear here."
            android:textColor="@color/my_plum"
            android:textSize="19sp"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/rgAnswers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_card"
            android:padding="14dp">

            <RadioButton
                android:id="@+id/rbAnswer1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Answer 1"
                android:textColor="@color/my_black"
                android:textSize="16sp"
                android:buttonTint="@color/my_plum" />

            <RadioButton
                android:id="@+id/rbAnswer2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Answer 2"
                android:textColor="@color/my_black"
                android:textSize="16sp"
                android:buttonTint="@color/my_plum" />

            <RadioButton
                android:id="@+id/rbAnswer3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Answer 3"
                android:textColor="@color/my_black"
                android:textSize="16sp"
                android:buttonTint="@color/my_plum" />
        </RadioGroup>

        <Button
            android:id="@+id/btnGenerateHint"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_secondary_button"
            android:text="Generate Hint"
            android:textAllCaps="false"
            android:textColor="@color/my_porcelain"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnExplainAnswer"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_secondary_button"
            android:text="Explain My Answer"
            android:textAllCaps="false"
            android:textColor="@color/my_porcelain"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnSubmitTask"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_primary_button"
            android:text="Submit"
            android:textAllCaps="false"
            android:textColor="@color/my_porcelain"
            android:textStyle="bold"
            app:backgroundTint="@null" />

    </LinearLayout>
</ScrollView>